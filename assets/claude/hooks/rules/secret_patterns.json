{
  "version": 1,
  "content_patterns": [
    { "name": "aws_access_key", "regex": "AKIA[0-9A-Z]{16}",              "severity": "critical" },
    { "name": "github_pat",     "regex": "gh[ps]_[A-Za-z0-9]{36,}",        "severity": "critical" },
    { "name": "slack_token",    "regex": "xox[bpars]-[A-Za-z0-9-]{10,}",   "severity": "critical" },
    { "name": "pem_block",      "regex": "-----BEGIN [A-Z ]*PRIVATE KEY-----", "severity": "critical" }
  ],
  "path_patterns": [
    { "name": "credentials_file", "regex": "(^|[/\\\\])\\.credentials([^/\\\\]*)$", "severity": "critical" },
    { "name": "env_file",         "regex": "(^|[/\\\\])\\.env(\\.[^/\\\\]+)?$",     "severity": "high" }
  ]
}
